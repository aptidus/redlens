# Backend env (api/) — set these on Railway. The app will start without
# them, but auth-gated endpoints will return 503 until they're configured.

# ── Required for AI analysis ────────────────────────────────────────────────
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5

# ── Postgres (Railway add-on gives you DATABASE_URL automatically) ──────────
DATABASE_URL=

# ── Clerk auth ──────────────────────────────────────────────────────────────
# Get from clerk.com → API Keys
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev
# Webhook signing secret from clerk.com → Webhooks
CLERK_WEBHOOK_SECRET=whsec_...

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins. In production: https://nichelens.ai
REDLENS_ALLOWED_ORIGINS=https://nichelens.ai

# ── Optional / legacy ───────────────────────────────────────────────────────
# Server-to-server header gate (still used by /api/login/qr if you re-enable it)
REDLENS_INTERNAL_TOKEN=
# HTTP Basic Auth for the staging URL (leave unset for nichelens.ai)
STAGING_USER=
STAGING_PASSWORD=
# Outbound proxy for XHS/Douyin scraping
OXYLABS_PROXY_URL=

# Frontend env (frontend/) — Vite reads VITE_-prefixed vars at build time.
# Goes into frontend/.env or Railway frontend build env.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
