{
  "manifest_version": 3,
  "name": "RedLens Cookie Connect",
  "version": "1.2.0",
  "description": "One-click connect your xiaohongshu.com session to RedLens. A floating button appears on XHS — click it to open RedLens already authenticated.",
  "permissions": ["cookies", "storage"],
  "host_permissions": [
    "https://*.xiaohongshu.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.xiaohongshu.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RedLens Cookie Connect",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
