{
  "manifest_version": 3,
  "name": "NicheLens Cookie Connect",
  "version": "1.4.0",
  "description": "Connect your xiaohongshu.com / douyin.com session to NicheLens. A floating button appears on each site, and authenticated API calls run inside your browser to bypass server-IP blocks.",
  "permissions": ["cookies", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://*.xiaohongshu.com/*",
    "https://*.douyin.com/*",
    "https://nichelens.ai/*",
    "https://*.nichelens.ai/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.xiaohongshu.com/*",
        "https://*.douyin.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://nichelens.ai/*",
        "https://*.nichelens.ai/*",
        "http://localhost/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NicheLens Cookie Connect",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
